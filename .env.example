# Miljövariabler för lokal körning av build_local_inventory.py.
# I GitHub Actions sätts dessa i stället som repo-secrets/variables.
# Kopiera till .env och fyll i. Committa ALDRIG .env.

# Abicart-produktfeed (TSV/XML). KRÄVS.
# Ex: https://admin.abicart.se/pricefile/153857/google/sv/SEK/SE
FEED_URL=

# Butikskod i Google Företagsprofil. Reserv om en rad saknar värde i feeden.
STORE_CODE=lagerplats_arsta

# Utfil. Lokalt valfritt (default: local_inventory.txt i repo-roten).
OUTPUT=local_inventory.txt

# Ta med slutsålda rader (1) eller bara det som finns i butik (0).
INCLUDE_OUT_OF_STOCK=1
